# Server Configuration
PORT=5000
NODE_ENV=development

# Database Settings
# Use MongoDB Atlas URL or a local string (e.g. mongodb://localhost:27017/ai-business-platform)
MONGODB_URI=mongodb://localhost:27017/ai-business-platform

# Authentication JWT
JWT_SECRET=supersecretjwtsecretkeychangeinproduction

# Google Gemini AI API Configuration
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
